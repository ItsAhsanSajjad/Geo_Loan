# GEO Loan — environment configuration (copy to .env and fill in)

# Prisma SQLite database URL.
# For local dev: file:/absolute/path/to/project/db/custom.db
# For production: switch to PostgreSQL, e.g.:
#   DATABASE_URL="postgresql://user:pass@host:5432/geoloan?schema=public"
# (and change `provider` in prisma/schema.prisma to "postgresql")
DATABASE_URL=file:./db/custom.db

# Secret used to sign session cookies (HMAC). REQUIRED in production (min 16 chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Where sensitive uploads (KYC docs, payment screenshots) are stored.
# MUST be a writable path OUTSIDE the public web root.
# On shared cPanel hosting use e.g. /home/<cpaneluser>/private_uploads
UPLOADS_DIR=./private_uploads

# Optional: initial admin password used only when seeding a fresh DB.
# ADMIN_INITIAL_PASSWORD=change-me-strong

# --- Super Admin (optional, top-level control panel at /superadmin) ---
# Credentials live ONLY here, never in source. Leave unset to disable the super admin.
# SUPERADMIN_PHONE=03xxxxxxxxx
# Preferred: store a BCRYPT HASH, not the plaintext. Generate one:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'YourStrongPassword'
# IMPORTANT: a bcrypt hash contains '$' chars. In a .env FILE you MUST escape each '$'
# as '\$' (e.g. \$2a\$10\$....) or dotenv will corrupt it. NOT needed when the value is
# set directly in the host's env-var UI (cPanel / Vercel / systemd).
# SUPERADMIN_PASSWORD_HASH=\$2a\$10\$....
# Dev-only convenience (plaintext, no '$' escaping needed). Use the hash in production:
# SUPERADMIN_PASSWORD=YourStrongPassword

# --- Memory limits for shared/cPanel hosting (set these as the app's env vars) ---
# Cap the V8 heap + libuv threads so resident memory stays low. (Node still
# reserves large VIRTUAL memory by design — a host vmem limit < ~1GB cannot run
# Node regardless of these; ask the host to raise vmem / enforce physical memory.)
# NODE_OPTIONS=--max-old-space-size=256
# UV_THREADPOOL_SIZE=2
